---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Bane Sullivan" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://banesullivan.com" />
    <meta property="og:image" content="https://banesullivan.com/profile.jpeg" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <main>
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} Bane Sullivan</p>
    </footer>
  </body>
</html>

<style is:global>
  /* --------------------------------------------------------
     Reset & Base
     -------------------------------------------------------- */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-text: #1a1a1a;
    --color-text-secondary: #555;
    --color-text-muted: #888;
    --color-bg: #fff;
    --color-border: #e5e5e5;
    --color-link: #0066cc;
    --color-link-hover: #004499;
    --max-width: 640px;
    --font-sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto,
      sans-serif;
    --font-mono: "JetBrains Mono", "Fira Code", monospace;
  }

  html {
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  body {
    font-family: var(--font-sans);
    color: var(--color-text);
    background: var(--color-bg);
    line-height: 1.7;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  /* --------------------------------------------------------
     Typography
     -------------------------------------------------------- */
  h1,
  h2,
  h3 {
    line-height: 1.3;
    font-weight: 600;
  }

  h1 {
    font-size: 1.75rem;
  }

  h2 {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--color-text-muted);
  }

  h3 {
    font-size: 1rem;
    margin-top: 1.5rem;
    margin-bottom: 0.25rem;
  }

  p {
    margin-bottom: 1rem;
    color: var(--color-text-secondary);
  }

  a {
    color: var(--color-link);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  a:hover {
    color: var(--color-link-hover);
  }

  ul {
    list-style: none;
    padding: 0;
  }

  /* --------------------------------------------------------
     Layout
     -------------------------------------------------------- */
  main {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
    flex: 1;
    width: 100%;
  }

  footer {
    text-align: center;
    padding: 2rem 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  footer p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* --------------------------------------------------------
     Header / Hero
     -------------------------------------------------------- */
  .hero {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .hero img {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .hero-text h1 {
    margin-bottom: 0.15rem;
  }

  .hero-text .tagline {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  /* --------------------------------------------------------
     Nav links (social row)
     -------------------------------------------------------- */
  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.25rem;
    margin-bottom: 2rem;
    font-size: 0.9rem;
  }

  .nav-links a {
    color: var(--color-text-muted);
    transition:
      color 0.15s ease,
      border-color 0.15s ease;
    border-bottom: 1px solid transparent;
  }

  .nav-links a:hover {
    color: var(--color-link);
    border-bottom-color: var(--color-link);
  }

  /* --------------------------------------------------------
     Section dividers
     -------------------------------------------------------- */
  .section {
    margin-bottom: 2rem;
  }

  hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }

  /* --------------------------------------------------------
     Intro / About text
     -------------------------------------------------------- */
  .intro p {
    font-size: 0.95rem;
  }

  /* --------------------------------------------------------
     Experience / Timeline
     -------------------------------------------------------- */
  .experience-item {
    margin-bottom: 1.5rem;
  }

  .experience-item h3 {
    margin-bottom: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
  }

  .experience-item h3 .role {
    font-weight: 400;
    color: var(--color-text-secondary);
    font-size: 0.9rem;
  }

  .experience-item .dates {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
  }

  .experience-item p {
    font-size: 0.9rem;
    margin-bottom: 0.25rem;
  }

  /* --------------------------------------------------------
     Projects
     -------------------------------------------------------- */
  .project-item {
    margin-bottom: 1.25rem;
  }

  .project-item h3 {
    margin-bottom: 0.1rem;
  }

  .project-item .project-meta {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    margin-bottom: 0.3rem;
  }

  .project-item p {
    font-size: 0.9rem;
  }

  /* --------------------------------------------------------
     Education
     -------------------------------------------------------- */
  .education-item {
    margin-bottom: 1rem;
  }

  .education-item h3 {
    margin-bottom: 0;
  }

  .education-item .details {
    font-size: 0.88rem;
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  /* --------------------------------------------------------
     Publications
     -------------------------------------------------------- */
  .publication-item {
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
  }

  .publication-item em {
    color: var(--color-text-secondary);
  }

  /* --------------------------------------------------------
     Responsive
     -------------------------------------------------------- */
  @media (max-width: 480px) {
    .hero {
      flex-direction: column;
      text-align: center;
    }

    .nav-links {
      justify-content: center;
    }

    h1 {
      font-size: 1.5rem;
    }
  }
</style>
